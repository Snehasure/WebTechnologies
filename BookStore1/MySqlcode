CREATE DATABASE bookstore; USE bookstore;
CREATE TABLE users (
id BIGINT AUTO_INCREMENT PRIMARY KEY, username VARCHAR(50) UNIQUE NOT NULL, password VARCHAR(255) NOT NULL,
email VARCHAR(100) UNIQUE NOT NULL
);
CREATE TABLE books (
id BIGINT AUTO_INCREMENT PRIMARY KEY, title VARCHAR(100) NOT NULL,
author VARCHAR(100) NOT NULL, price DECIMAL(10, 2) NOT NULL,
isbn VARCHAR(13) UNIQUE NOT NULL
);
CREATE TABLE user_books ( user_id BIGINT NOT NULL, book_id BIGINT NOT NULL, PRIMARY KEY (user_id, book_id),
FOREIGN KEY (user_id) REFERENCES users(id), FOREIGN KEY (book_id) REFERENCES books(id)
);
